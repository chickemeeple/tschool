{
  "name": "basegame",
  "version": "1.0.0",
  "description": "Basic game, to use for other projects.",
  "main": "index.js",
  "scripts": {
    "server:build": "tsc -p tsconfig.server.json --watch",
    "client:build:dev": "webpack --mode development && rsync -avz --include='*.ejs' --exclude='*' ./src/client/ ./dist",
    "client:build:prod": "webpack --mode production && rsync -avz --include='*.ejs' --exclude='*' ./src/client/ ./dist",
    "server": "nodemon --inspect build/server/index.js",
    "client:watch": "chokidar \"src/client/**/*\" -c \"npm run client:build\""
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "chokidar-cli": "^3.0.0",
    "express": "^5.2.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pixi.js": "^8.14.3",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "sqlite3": "^5.1.7",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.56.0",
    "validator": "^13.15.26",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
