{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],     // NO DOM
    "types": ["node"],     // Node APIs
    "rootDir": "src/server",
    "outDir": "build/server",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true
  },
  "include": ["src/server/**/*"],
  "exclude": ["src/client"]
}
